#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
STATE_DIR="${CLAUDE_CODEX_LOCAL_STATE_DIR:-$ROOT/.claude-codex-local}"
MODE="${CLAUDE_CODEX_LOCAL_MODE:-balanced}"

REC="$(python3 "$ROOT/poc_bridge.py" recommend --mode "$MODE")"
MODEL="${CLAUDE_CODEX_LOCAL_MODEL:-$(printf '%s' "$REC" | python3 -c 'import json,sys; print(json.load(sys.stdin)["selected_model"])')}"
RUNTIME="$(printf '%s' "$REC" | python3 -c 'import json,sys; print(json.load(sys.stdin)["runtime"])')"

python3 "$ROOT/poc_bridge.py" ensure-config claude --model "$MODEL" --mode "$MODE" >/dev/null
printf 'configured Claude integration in %s using runtime=%s model=%s mode=%s\n' "$STATE_DIR" "$RUNTIME" "$MODEL" "$MODE"
