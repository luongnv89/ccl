#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
STATE_DIR="${CLAUDE_CODEX_LOCAL_STATE_DIR:-$ROOT/.claude-codex-local}"
MODE="${CLAUDE_CODEX_LOCAL_MODE:-balanced}"
HOME_ORIG="${HOME:-$HOME}"

REC="$(python3 "$ROOT/poc_bridge.py" recommend --mode "$MODE")"
MODEL="${CLAUDE_CODEX_LOCAL_MODEL:-$(printf '%s' "$REC" | python3 -c 'import json,sys; print(json.load(sys.stdin)["selected_model"])')}"
RUNTIME="$(printf '%s' "$REC" | python3 -c 'import json,sys; print(json.load(sys.stdin)["runtime"])')"

# Map bridge runtime name to the codex --local-provider value
case "$RUNTIME" in
  lmstudio) PROVIDER="lmstudio" ;;
  *)        PROVIDER="ollama" ;;
esac

python3 "$ROOT/poc_bridge.py" ensure-config codex --model "$MODEL" --mode "$MODE" >/dev/null

# If using LM Studio, ensure the server is running right before we hand off to codex.
# LM Studio auto-stops after idle periods; starting it here closes the race window.
if [ "$PROVIDER" = "lmstudio" ]; then
  if command -v lms >/dev/null 2>&1; then
    lms server start >/dev/null 2>&1 || true
  elif [ -x "$HOME_ORIG/.lmstudio/bin/lms" ]; then
    "$HOME_ORIG/.lmstudio/bin/lms" server start >/dev/null 2>&1 || true
  fi
fi

export HOME="$STATE_DIR/home"
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
printf 'claude-codex-local: runtime=%s provider=%s model=%s mode=%s state=%s\n' "$RUNTIME" "$PROVIDER" "$MODEL" "$MODE" "$STATE_DIR" >&2

if [ "${1:-}" = "exec" ]; then
  shift
  exec codex exec --oss --local-provider "$PROVIDER" -m "$MODEL" "$@"
fi

exec codex --oss --local-provider "$PROVIDER" -m "$MODEL" "$@"
