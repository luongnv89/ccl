# Scenario: install via uv from pre-built wheel
# Base: minimal Python image with uv installed, no project dependencies pre-installed.
FROM python:3.11-slim

ARG WHEEL_FILE
WORKDIR /install

# Install uv
RUN pip install --no-cache-dir uv

COPY dist/${WHEEL_FILE} .

RUN uv pip install --system --no-cache ${WHEEL_FILE}

# Verify entry point is present and functional.
RUN ccl --help > /dev/null 2>&1 && \
    ccl --version > /dev/null 2>&1 && \
    python -m claude_codex_local.core adapters > /dev/null 2>&1

CMD ["echo", "uv install scenario: PASS"]
