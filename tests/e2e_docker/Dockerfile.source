# Scenario: install from source via pip install .
# Base: minimal Python image with no project dependencies pre-installed.
FROM python:3.11-slim

WORKDIR /src

# Copy source tree (excluding heavy dirs via .dockerignore).
COPY . .

RUN pip install --no-cache-dir .

# Verify entry point is present and functional.
RUN ccl --help > /dev/null 2>&1 && \
    ccl --version > /dev/null 2>&1 && \
    python -m claude_codex_local.core adapters > /dev/null 2>&1

CMD ["echo", "install from source scenario: PASS"]
